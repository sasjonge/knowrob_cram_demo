{
    "logging": {
      "console-sink": { "level": "debug" },
      "file-sink": {
        "level": "debug",
        "path": "/root"
      }
    },
    "semantic-web": {
        "prefixes": [
          { "alias":  "SOMA", "uri":  "http://www.ease-crc.org/ont/SOMA.owl" },
          { "alias":  "owl", "uri":  "http://www.w3.org/2002/07/owl" },
          { "alias":  "rdf", "uri":  "http://www.w3.org/1999/02/22-rdf-syntax-ns" },
          { "alias":  "rdfs", "uri":  "http://www.w3.org/2000/01/rdf-schema" },
          { "alias":  "xsd", "uri":  "http://www.w3.org/2001/XMLSchema" }
        ]
      },
      "data-sources": [
        {
          "path": "http://www.ease-crc.org/ont/SOMA.owl",
          "format": "rdf-xml"
        }
    ],
    "data-backends": [
      {
        "name": "pl",
        "type": "Prolog:rdf_db"
      }
    ],
    "reasoner": [
      {
        "name": "pl",
        "type": "Prolog",
        "data-backend": "pl",
        "imports": [
          {
            "path": "../knowrob_cram_demo/src/objects.pl",
            "format": "prolog"
          }
        ]
      }
    ]
  }